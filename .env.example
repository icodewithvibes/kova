# Kova environment configuration
# The app runs fully in mock mode with NO variables set. Copy to .env to override.

# AI provider: mock | cloud | ollama  (mock is the default and requires nothing)
VITE_AI_PROVIDER=mock

# Cloud AI (Phase 7+; requires a server-side proxy — NEVER put a raw API key here.
# Raw provider keys must not ship to the browser.)
VITE_FEATURE_CLOUD=false
VITE_CLOUD_AI_BASE_URL=

# Local AI via Ollama on this machine or LAN (feature-flagged; requires owner-approved install)
VITE_FEATURE_OLLAMA=false
VITE_OLLAMA_BASE_URL=http://localhost:11434
# Local model, or an Ollama Cloud model (name ends in "-cloud"; needs `ollama signin`, free tier limits)
VITE_OLLAMA_MODEL=qwen3:8b
